rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // Récupère le doc équipe correspondant à l'utilisateur connecté.
    // Convention : le doc id de la collection "equipe" == request.auth.uid.
    function memberDoc() {
      return get(/databases/$(database)/documents/equipe/$(request.auth.uid));
    }

    function role() {
      return memberDoc().data.role;
    }

    function isActive() {
      return memberDoc().data.actif == true;
    }

    function isAdmin() {
      return isSignedIn() && isActive() && (role() == "superadmin" || role() == "admin");
    }

    function isStaff() {
      return isSignedIn() && isActive() && role() in [
        "superadmin", "admin", "chef", "chauffeur",
        "monteur", "preparateur", "apporteur"
      ];
    }

    function isApporteur() {
      return isSignedIn() && isActive() && role() == "apporteur";
    }

    function apporteurName() {
      return memberDoc().data.nom;
    }

    // Version normalisée pour matching case-insensitive avec resource.data.apporteurLower
    // (champ dénormalisé sur clients/livraisons/velos via scripts/backfill-apporteur-lower.mjs).
    // Évite que "Thierry Bismuth" en equipe ≠ "thierry bismuth" sur un client.
    function apporteurNameLower() {
      return memberDoc().data.nom.lower();
    }

    // equipe : un membre peut lire son propre doc; admin lit/écrit tout.
    match /equipe/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Données métier : tout le staff actif lit, admin écrit.
    // Cas spécial apporteur (RBAC commercial 2026-04-28) : un apporteur ne
    // voit QUE les clients dont le champ apporteurLower (dénormalisé,
    // case-insensitive) matche son nom normalisé. Les autres rôles staff
    // voient tout. Le frontend doit query avec where("apporteurLower","==",
    // userName.toLowerCase().trim()) sinon Firestore rejette le snapshot.
    // Cf. memory crm_velos_cargo_apporteurs.
    match /clients/{id} {
      allow read: if isAdmin()
                  || (isStaff() && !isApporteur())
                  || (isApporteur() && resource.data.apporteurLower == apporteurNameLower());
      allow write: if isAdmin();
    }

    // Vélos : update ouvert au staff terrain pour le marquage d'étapes
    // (préparation, chargement, livraison, montage) + photos montage.
    // Apporteur : lecture seule sur les vélos de SES clients (via
    // apporteurLower dénormalisé). Pas d'update apporteur (ils ne touchent
    // pas au flux opérationnel terrain).
    match /velos/{id} {
      allow read: if isAdmin()
                  || (isStaff() && !isApporteur())
                  || (isApporteur() && resource.data.apporteurLower == apporteurNameLower());
      allow update: if isStaff() && !isApporteur();
      allow create, delete: if isAdmin();
    }

    // Livraisons : update ouvert au staff terrain pour passer le statut à
    // "livree", poser dateEffective et l'urlBlSigne. Apporteur : lecture
    // seule sur les livraisons de SES clients (= il voit quand son client
    // est livré). Pas d'update apporteur.
    match /livraisons/{id} {
      allow read: if isAdmin()
                  || (isStaff() && !isApporteur())
                  || (isApporteur() && resource.data.apporteurLower == apporteurNameLower());
      allow update: if isStaff() && !isApporteur();
      allow create, delete: if isAdmin();
    }

    match /tournees/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /camions/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /bonsEnlevement/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /verifications/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Paramètres globaux (ex : config app, branding)
    match /settings/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Tout le reste est refusé par défaut.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
