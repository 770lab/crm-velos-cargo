rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // Récupère le doc équipe correspondant à l'utilisateur connecté.
    // Convention : le doc id de la collection "equipe" == request.auth.uid.
    function memberDoc() {
      return get(/databases/$(database)/documents/equipe/$(request.auth.uid));
    }

    function role() {
      return memberDoc().data.role;
    }

    function isActive() {
      return memberDoc().data.actif == true;
    }

    function isAdmin() {
      return isSignedIn() && isActive() && (role() == "superadmin" || role() == "admin");
    }

    function isStaff() {
      return isSignedIn() && isActive() && role() in [
        "superadmin", "admin", "chef", "chauffeur",
        "monteur", "preparateur", "apporteur"
      ];
    }

    function isApporteur() {
      return isSignedIn() && isActive() && role() == "apporteur";
    }

    function apporteurName() {
      return memberDoc().data.nom;
    }

    // Version normalisée pour matching case-insensitive avec resource.data.apporteurLower
    // (champ dénormalisé sur clients/livraisons/velos via scripts/backfill-apporteur-lower.mjs).
    // Évite que "Thierry Bismuth" en equipe ≠ "thierry bismuth" sur un client.
    function apporteurNameLower() {
      return memberDoc().data.nom.lower();
    }

    // equipe : tout staff actif lit (annuaire interne — noms affichés dans
    // l'UI livraisons "préparé par X", "chargé par Y", affectations équipe).
    // Sans cette règle un chauffeur loggué reçoit "Missing or insufficient
    // permissions" sur la requête `equipe` du data-context (bug 2026-04-29).
    // Écriture : admin only.
    match /equipe/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isStaff());
      allow write: if isAdmin();
    }

    function isChauffeur() {
      return isSignedIn() && isActive() && role() == "chauffeur";
    }
    function isMonteur() {
      return isSignedIn() && isActive() && role() == "monteur";
    }
    function isPreparateur() {
      return isSignedIn() && isActive() && role() == "preparateur";
    }

    // Données métier : tout le staff actif lit, admin écrit.
    // Cas spécial apporteur (RBAC commercial 2026-04-28) : un apporteur ne
    // voit QUE les clients dont le champ apporteurLower (dénormalisé,
    // case-insensitive) matche son nom normalisé. Les autres rôles staff
    // voient tout. Le frontend doit query avec where("apporteurLower","==",
    // userName.toLowerCase().trim()) sinon Firestore rejette le snapshot.
    // Cf. memory crm_velos_cargo_apporteurs.
    match /clients/{id} {
      allow read: if isAdmin()
                  || (isStaff() && !isApporteur())
                  || (isApporteur() && resource.data.apporteurLower == apporteurNameLower());
      allow write: if isAdmin();
      // Yoann 2026-05-03 : apporteur peut écrire UNIQUEMENT le champ
      // apporteurNote (commentaire libre) sur ses propres clients.
      // Tous les autres champs restent verrouillés (read-only ailleurs).
      allow update: if isApporteur()
                    && resource.data.apporteurLower == apporteurNameLower()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['apporteurNote', 'apporteurNoteAt', 'updatedAt']);
    }

    // Vélos : update ouvert au staff terrain pour le marquage d'étapes
    // (préparation, chargement, livraison, montage) + photos montage.
    // Apporteur : lecture seule sur les vélos de SES clients (via
    // apporteurLower dénormalisé). Pas d'update apporteur (ils ne touchent
    // pas au flux opérationnel terrain).
    match /velos/{id} {
      allow read: if isAdmin()
                  || (isStaff() && !isApporteur())
                  || (isApporteur() && resource.data.apporteurLower == apporteurNameLower());
      allow update: if isStaff() && !isApporteur();
      allow create, delete: if isAdmin();
    }

    // Livraisons : update ouvert au staff terrain. Lecture ouverte au staff
    // non-apporteur — le filtrage chauffeur/monteur/preparateur (= ne voir
    // QUE ses tournées) est fait côté frontend (data-context-firebase) pour
    // simplicité. On garde la lecture serveur permissive parce que les
    // rôles terrain sont déjà du staff trusted ; cf. décision 2026-04-29
    // après tentative de rule stricte chauffeurId qui cassait toutes les
    // queries `where(tourneeId)` (markVeloCharge, getBlForTournee, etc.).
    match /livraisons/{id} {
      allow read: if isAdmin()
                  || (isStaff() && !isApporteur())
                  || (isApporteur() && resource.data.apporteurLower == apporteurNameLower());
      allow update: if (isStaff() && !isApporteur())
                    || (isApporteur()
                        && resource.data.apporteurLower == apporteurNameLower()
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['apporteurNote', 'apporteurNoteAt', 'updatedAt']));
      allow create, delete: if isAdmin();
    }

    // Yoann 2026-05-03 : RBAC apporteur durci — un apporteur n a aucun
    // besoin opérationnel de lire les tournées / camions / bons retrait
    // AXDIS / dispos / entrepôts / flotte / commandes camion / sessions
    // atelier / sessions sur site. On exclut les apporteurs en lecture
    // sur toutes ces collections (ils restent autorisés à lire leurs
    // clients / vélos / livraisons via le filtre apporteurLower).
    match /tournees/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
    }

    match /camions/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
    }

    match /bonsEnlevement/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
    }

    match /verifications/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Paramètres globaux (ex : config app, branding)
    match /settings/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Disponibilités d'une journée (camions / chauffeurs / chefs / monteurs).
    // Écrites par setDisponibilites (admin via day-planner-modal), lues par
    // tout le staff non-apporteur.
    match /disponibilites/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
    }

    // Compteurs séquentiels (ex : counters/bl-2026 pour numéros BL).
    // Lus + incrémentés en transaction par getBlForTournee. Apporteur
    // exclu : il n'imprime pas de BL et ne devrait pas pouvoir incrémenter.
    match /counters/{id} {
      allow read, write: if isStaff() && !isApporteur();
    }

    // Frais opérationnels (saisie manuelle page /finances).
    // Admin only — sensibilité comptable.
    match /frais/{id} {
      allow read, write: if isAdmin();
    }

    // Config finances (prix d'achat vélo HT, paramètres globaux).
    match /config/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Entrepôts (Yoann 2026-05-01 : AXDIS + 3 stocks Nanterre/Lisses/Chelles).
    // Lecture par tout le staff (chauffeurs / monteurs / chefs ont besoin de
    // voir les stocks pour la logistique). Écriture admin uniquement.
    match /entrepots/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
      // Mouvements de stock (entrées datées, manuelles ou auto)
      match /mouvements/{mvtId} {
        allow read: if isStaff() && !isApporteur();
        allow write: if isAdmin();
      }
    }

    // Flotte de camions (Yoann 2026-05-03) : capacités cartons/montés,
    // restrictions Paris. Lecture staff non-apporteur, écriture admin.
    match /flotte/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
    }

    // Commandes de camions complets passées à Tiffany (Yoann 2026-05-01).
    // Numéro incrémental "VELO CARGO - COMMANDE N" pour matching avec les
    // bons de retour AXDIS. Sensible (volumes commandés = stratégique).
    match /commandesCamion/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
    }

    // Paiements équipe (Yoann 2026-05-01) : grand livre traçabilité
    // comptable. Salaires payés, avances, primes par membre.
    // Lecture admin/superadmin (RH sensible), écriture admin.
    function isChef() {
      return isSignedIn() && isActive() && role() == "chef";
    }
    match /paiementsEquipe/{id} {
      // Yoann 2026-05-03 : les chefs d équipe (Ricky/ETHAN/...) doivent
      // pouvoir lire + écrire les paiements de leurs monteurs (grand livre
      // pointeuse). Le filtre par équipe se fait côté frontend (sur chefId
      // du monteur). Admin garde l accès complet.
      allow read: if isAdmin() || isChef();
      allow write: if isAdmin() || isChef();
    }

    // Sessions de montage atelier (Yoann 2026-05-01) : journées où des
    // monteurs viennent à un entrepôt pour faire du montage en masse.
    // Lecture par tout le staff (les monteurs voient leur planning),
    // écriture admin uniquement.
    match /sessionsMontageAtelier/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
    }

    // Sessions sur site client (Yoann 2026-05-03) : pour groupes type
    // Firat où le camion client distribue ses propres magasins. Lecture
    // staff non-apporteur, écriture admin.
    match /sessionsSurSite/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isAdmin();
    }

    // Brief logistique du jour (Yoann 2026-05-03) : note libre par date
    // (id = YYYY-MM-DD) pour décrire les cascades inter-équipes que les
    // livraisons brutes ne révèlent pas (ex enchaînements chauffeur,
    // monteur qui change d équipe en cours de journée). Réinjectée dans
    // le brief WhatsApp ET les prompts Gemini. Lecture+écriture par tout
    // le staff non-apporteur (chefs/chauffeurs peuvent annoter aussi).
    match /briefsJour/{id} {
      allow read: if isStaff() && !isApporteur();
      allow write: if isStaff() && !isApporteur();
    }

    // Tout le reste est refusé par défaut.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
